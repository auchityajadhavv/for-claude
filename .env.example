# Copy to .env.local for local dev, and add the same keys in Vercel → Settings → Environment Variables.

# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Your owner email (lowercase). Only this account can reach /dashboard.
VITE_OWNER_EMAIL=you@revora.in
